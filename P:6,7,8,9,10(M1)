//Code3:(Practicle:8) 8. Read a CSV file and calculate basic statistics for each numeric column. Use the scala-csv library or similar tools.
import com.github.tototoshi.csv._
import java.io.File

object Pract_8_Trisha extends App {

  // Step 1 & 2: Read the CSV file and load all records with headers into memory
  private val reader = CSVReader.open(new File("employees.csv"))
  private val rows: List[Map[String, String]] = reader.allWithHeaders()
  reader.close()

  private val headers = rows.headOption.map(_.keys.toList).getOrElse(List())

  println(s"Total records read: ${rows.length}")
  println(s"Columns found: ${headers.mkString(", ")}\n")

  // Step 3: Go through each column and check if it is numeric
  for (col <- headers) {

    // Step 4 & 5: Get each value and safely try converting String -> Double
    val numericValues: List[Double] =
      rows.flatMap(row => row.get(col).flatMap(_.trim.toDoubleOption))

    // A column is treated as numeric only if EVERY row converted successfully
    if (numericValues.nonEmpty && numericValues.length == rows.length) {

      val count    = numericValues.length
      val sum      = numericValues.sum
      val mean     = sum / count
      val minVal   = numericValues.min
      val maxVal   = numericValues.max
      val variance = numericValues.map(v => math.pow(v - mean, 2)).sum / count
      val stdDev   = math.sqrt(variance)

      // Step 6, 7, 8: Print statistics for that column
      println(s"Column: $col")
      println(f"  Count   : $count")
      println(f"  Sum     : $sum%.2f")
      println(f"  Mean    : $mean%.2f")
      println(f"  Min     : $minVal%.2f")
      println(f"  Max     : $maxVal%.2f")
      println(f"  StdDev  : $stdDev%.2f")
      println()
    } else {
      println(s"Column: $col  -> Not numeric, skipped\n")
    }
  }
}
//Code4:(Practicle:9)Handle missing values in a dataset. Replace missing values with the column mean.
import com.github.tototoshi.csv._
import java.io.File
import scala.util.Try

object Pract_9_Trisha_S086 {
  def main(args: Array[String]): Unit = {

    val inputFile = new File("students.csv")
    val reader = CSVReader.open(inputFile)
    val allRows = reader.allWithHeaders()
    reader.close()

    val numericColumns = Seq("Age", "Marks") // updated based on students.csv columns

    // Step 1: Compute means and missing counts
    val stats: Map[String, (Double, Int)] = numericColumns.map { col =>
      val values = allRows.map(row => row.getOrElse(col, "").trim)
      val validNumbers = values.flatMap(v => Try(v.toDouble).toOption)
      val missingCount = values.count(v => Try(v.toDouble).isFailure)
      val mean = if (validNumbers.nonEmpty) validNumbers.sum / validNumbers.size else 0.0
      (col, (mean, missingCount))
    }.toMap

    // Step 2: Print stats for each column
    println("\n--- Missing Data Report ---")
    stats.foreach { case (col, (mean, missingCount)) =>
      println(f"Column: $col, Missing values: $missingCount, Replaced with mean: $mean%.2f")
    }

    // Step 3: Replace missing values
    val cleanedRows = allRows.map { row =>
      numericColumns.foldLeft(row) { (accRow, col) =>
        val value = accRow.getOrElse(col, "").trim
        val replaced = Try(value.toDouble).toOption match {
          case Some(_) => value
          case None    => f"${stats(col)._1}%.2f"
        }
        accRow.updated(col, replaced)
      }
    }

    // Step 4: Save cleaned CSV
    val outputFile = new File("students_cleaned.csv")
    val writer = CSVWriter.open(outputFile)
    val headers = cleanedRows.head.keys.toSeq
    writer.writeRow(headers)
    cleanedRows.foreach(row => writer.writeRow(headers.map(row)))
    writer.close()

    println("\nMissing values replaced and saved to students_cleaned.csv")
  }
}

code5:(Practicle:10)Filter rows in a dataset where a specific column value exceeds a threshold.
import com.github.tototoshi.csv._
import java.io.File

object Pract_10_Trisha_S086 {
  def main(args: Array[String]): Unit = {

    val reader = CSVReader.open(new File("sales.csv"))
    val data = reader.allWithHeaders()
    reader.close()

    val threshold = 10000

    // Filter rows where "Revenue" > threshold
    val filteredRows = data.filter { row =>
      row.get("Revenue").exists(value => value.toIntOption.exists(_ > threshold))
    }

    println(s"\nTotal Rows with Revenue > $threshold: ${filteredRows.length}\n")

    // Print each filtered row
    filteredRows.foreach { row =>
      println(row.values.mkString(", "))
    }
  }
}
